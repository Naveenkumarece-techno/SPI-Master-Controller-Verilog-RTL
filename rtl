module spi_master #(
    parameter DATA_WIDTH = 8,
    parameter CLK_DIV = 4
)(
    input  wire clk,
    input  wire rst,
    input  wire start,
    input  wire [DATA_WIDTH-1:0] mosi_data,
    output reg  miso,
    input  wire miso_in,
    output reg  sclk,
    output reg  cs,
    output reg  done
);

    // FSM states
    parameter IDLE  = 2'b00;
    parameter LOAD  = 2'b01;
    parameter TRANS = 2'b10;
    parameter FINISH= 2'b11;

    reg [1:0] state;

    reg [DATA_WIDTH-1:0] shift_reg;
    reg [3:0] bit_cnt;

    reg [15:0] clk_cnt;
    reg spi_clk_en;

    // Clock divider for SPI clock
    always @(posedge clk or posedge rst) begin
        if (rst) begin
            clk_cnt <= 0;
            spi_clk_en <= 0;
        end else begin
            if (clk_cnt == CLK_DIV) begin
                clk_cnt <= 0;
                spi_clk_en <= 1;
            end else begin
                clk_cnt <= clk_cnt + 1;
                spi_clk_en <= 0;
            end
        end
    end

    // FSM
    always @(posedge clk or posedge rst) begin
        if (rst) begin
            state <= IDLE;
            sclk <= 0;
            cs <= 1;
            done <= 0;
            bit_cnt <= 0;
            shift_reg <= 0;
            miso <= 0;
        end else begin
            case (state)

                IDLE: begin
                    cs <= 1;
                    sclk <= 0;
                    done <= 0;

                    if (start) begin
                        state <= LOAD;
                    end
                end

                LOAD: begin
                    cs <= 0;
                    shift_reg <= mosi_data;
                    bit_cnt <= DATA_WIDTH;
                    state <= TRANS;
                end

                TRANS: begin
                    if (spi_clk_en) begin
                        sclk <= ~sclk;

                        if (sclk == 0) begin
                            // transmit on falling edge
                            miso <= shift_reg[DATA_WIDTH-1];
                            shift_reg <= shift_reg << 1;
                            shift_reg[0] <= miso_in;
                            bit_cnt <= bit_cnt - 1;

                            if (bit_cnt == 1)
                                state <= FINISH;
                        end
                    end
                end

                FINISH: begin
                    cs <= 1;
                    done <= 1;
                    state <= IDLE;
                end

            endcase
        end
    end

endmodule
